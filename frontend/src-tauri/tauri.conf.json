{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "NexusForge",
  "version": "1.0.0",
  "identifier": "com.nexusforge.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "NexusForge · 星枢 - AI 长篇小说创作平台",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "center": true,
        "decorations": true,
        "resizable": true,
        "fullscreen": false,
        "devtools": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; style-src-elem 'self' 'unsafe-inline'; style-src-attr 'unsafe-inline'; img-src 'self' asset: data: blob:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost http://127.0.0.1:* ws://127.0.0.1:* http://localhost:* ws://localhost:*; frame-src 'none'; object-src 'none'; base-uri 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../../out/tauri/nexusforge-backend/": "nexusforge-backend/"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      },
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "nsis": {
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico",
        "installMode": "both",
        "languages": [
          "SimpChinese",
          "English"
        ]
      }
    },
    "shortDescription": "AI 驱动的长篇小说创作平台",
    "longDescription": "NexusForge（星枢）是一款融合星渊笔引擎内核与墨枢前端架构的 AI 长篇小说创作平台，提供自动驾驶写作、质量护栏、剧情 DAG 可视化、文风漂移检测等专业功能。",
    "category": "Productivity",
    "publisher": "NexusForge Team",
    "copyright": "© 2025 NexusForge Team. All rights reserved."
  },
  "plugins": {}
}
