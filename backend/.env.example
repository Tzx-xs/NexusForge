# ---- 基础配置 ----
APP_ENV=production
# 桌面应用默认 127.0.0.1（仅本机访问）；公网部署改为 0.0.0.0
APP_HOST=127.0.0.1
APP_PORT=8000
DEBUG=false

# ---- 跨域（本地桌面应用；部署到公网请改为具体域名）----
CORS_ORIGINS=http://localhost:5173,http://localhost:1420,tauri://localhost

# ---- API 认证 ----
# 桌面应用场景：启动时自动生成随机 key（start.py），无需手动设置
# 公网部署：手动设置强随机字符串
API_KEY=

# ---- 加密 ----
# AES-GCM 加密密钥（64 字符 hex）；生产环境必须设置！
# 生成命令: python -c "import secrets; print(secrets.token_hex(32))"
# 留空时仅开发模式可用（基于机器信息派生），生产环境启动会失败
ENCRYPTION_KEY=

# ---- 数据库 ----
DATABASE_URL=sqlite:///./data/xingyuanbi.db

# ---- LLM 配置 ----
# 支持的提供者：openai, anthropic, ollama
# local 仅作为开发兜底，不对外暴露
LLM_PROVIDER=ollama
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096
LLM_TIMEOUT=120

# ---- 生成配置 ----
GENERATION_MAX_RETRIES=2
GENERATION_STREAMING=true
OUTLINE_TARGET_WORDS=500
CONTENT_TARGET_WORDS=2000

# ---- 日志 ----
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# ============================================
#              模型配置说明
# ============================================
#
# 星渊笔不内置 AI 模型，请根据您的需求配置以下任意一种：
#
# 1. 使用 OpenAI 兼容 API
# -----------------------
# LLM_PROVIDER=openai
# LLM_API_KEY=your-api-key
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
#
# 2. 使用 Anthropic API
# ----------------------
# LLM_PROVIDER=anthropic
# LLM_API_KEY=your-anthropic-api-key
# LLM_BASE_URL=https://api.anthropic.com/v1
# LLM_MODEL=claude-3-haiku-20240307
#
# 3. 使用本地 Ollama（推荐）
# -------------------------
# 1. 安装 Ollama: https://ollama.com/download
# 2. 拉取模型: ollama pull qwen2.5:14b
# 3. 启动服务: ollama serve
# 4. 配置如下：
# LLM_PROVIDER=ollama
# LLM_API_KEY=
# LLM_BASE_URL=http://localhost:11434
# LLM_MODEL=qwen2.5:14b
#
# 4. 开发模式（使用模拟数据）
# --------------------------
# LLM_PROVIDER=local
# 此模式不调用真实模型，返回模拟数据用于开发测试
